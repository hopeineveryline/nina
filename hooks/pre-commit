#!/bin/sh
# Pre-commit hook for nina

cargo_changed=false
src_changed=false

for file in $(git diff --cached --name-only); do
    case "$file" in
        Cargo.toml) cargo_changed=true ;;
        src/*)      src_changed=true ;;
    esac
done

if [ "$src_changed" = true ] && [ "$cargo_changed" != true ]; then
    echo "error: source files changed but Cargo.toml version was not bumped."
    echo "  PATCH for fixes, MINOR for features, MAJOR for breaking changes."
    exit 1
fi

if [ "$cargo_changed" = true ]; then
    version=$(grep '^version = ' Cargo.toml | tr -d ' "')
    if ! git tag | grep -q "^v$version\$"; then
        echo "error: version bumped to $version but not tagged or released."
        echo "  Run: git tag v$version && git push --tags"
        echo "       gh release create v$version --generate-notes"
        exit 1
    fi
fi
